generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(cuid())
  uid               String             @unique
  name              String
  email             String             @unique // Institutional email (lastname.firstname@ptc.edu.ph)
  personalEmail     String?            // Personal email for sending credentials
  password          String
  role              String             @default("faculty")
  departmentId      String?
  contractType      String             @default("full-time")
  maxUnits          Int                @default(24)
  specialization    String             @default("[]")
  image             String?
  phone             String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  department        Department?        @relation(fields: [departmentId], references: [id])
  preferences       FacultyPreference?
  notifications     Notification[]
  schedules         Schedule[]
  scheduleLogs      ScheduleLog[]
  scheduleResponses ScheduleResponse[]
  auditLogs         AuditLog[]

  @@index([email])
  @@index([role])
  @@index([departmentId])
  @@index([personalEmail])
}

model Department {
  id        String    @id @default(cuid())
  name      String    @unique
  code      String?
  college   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  users     User[]
  programs  Program[]
  sections  Section[]
}

// ============================================================================
// PROGRAM MODEL - Intermediate layer between Department and Subject
// ============================================================================
model Program {
  id           String   @id @default(cuid())
  name         String
  code         String?  @unique
  description  String?
  departmentId String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  subjects   Subject[]
  sections   Section[]
  
  @@unique([name, departmentId])
  @@index([departmentId])
  @@index([isActive])
}

model Subject {
  id                     String     @id @default(cuid())
  subjectCode            String     // Subject code (can be reused across different programs)
  subjectName            String
  description            String?
  units                  Int
  programId              String     // Links to Program (which then links to Department)
  departmentId           String     // Denormalized for quick queries - must match program.departmentId
  yearLevel              Int        @default(1) // Year Level: 1=First Year, 2=Second Year, 3=Third Year, 4=Fourth Year
  semester               String     @default("1st Semester") // "1st Semester", "2nd Semester", "Summer"
  requiredSpecialization String     @default("[]")
  defaultDurationHours   Int        @default(3) // Duration in hours (e.g., 3 for a 3-hour class)
  isActive               Boolean    @default(true)
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt
  schedules              Schedule[]
  program                Program    @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([subjectCode, programId])  // Subject code must be unique within a program, but can be reused across programs
  @@index([programId])
  @@index([departmentId])
  @@index([isActive])
  @@index([yearLevel])
  @@index([semester])
}

model Room {
  id        String     @id @default(cuid())
  roomName  String     @unique
  roomCode  String?
  capacity  Int
  equipment String     @default("[]")
  building  String
  floor     Int?
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  schedules Schedule[]
}

model Section {
  id           String     @id @default(cuid())
  sectionName  String     @unique
  sectionCode  String?
  yearLevel    Int
  departmentId String
  programId    String?    // Optional link to program - sections can belong to a specific program
  studentCount Int
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  schedules    Schedule[]
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  program      Program?   @relation(fields: [programId], references: [id], onDelete: SetNull)

  @@index([departmentId])
  @@index([programId])
}

model Schedule {
  id           String            @id @default(cuid())
  subjectId    String
  facultyId    String
  sectionId    String
  roomId       String
  day          String
  startTime    String
  endTime      String
  status       String            @default("generated")
  semester     String?
  academicYear String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  faculty      User              @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  room         Room              @relation(fields: [roomId], references: [id], onDelete: Cascade)
  section      Section           @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subject      Subject           @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  logs         ScheduleLog[]
  response     ScheduleResponse?

  @@index([facultyId, day, startTime])
  @@index([roomId, day, startTime])
  @@index([sectionId, day, startTime])
}

model ScheduleResponse {
  id          String    @id @default(cuid())
  scheduleId  String    @unique
  facultyId   String
  status      String    @default("pending")
  reason      String?
  respondedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  faculty     User      @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  schedule    Schedule  @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([facultyId])
  @@index([status])
}

model FacultyPreference {
  id                 String   @id @default(cuid())
  facultyId          String   @unique
  preferredDays      String   @default("[]")
  preferredTimeStart String   @default("08:00")
  preferredTimeEnd   String   @default("17:00")
  preferredSubjects  String   @default("[]")
  unavailableDays    String?
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  faculty            User     @relation(fields: [facultyId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("info")
  read      Boolean  @default(false)
  actionUrl String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model ScheduleLog {
  id         String   @id @default(cuid())
  scheduleId String
  modifiedBy String
  oldValue   String   @default("{}")
  newValue   String   @default("{}")
  action     String
  reason     String?
  timestamp  DateTime @default(now())
  user       User     @relation(fields: [modifiedBy], references: [id], onDelete: Cascade)
  schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId])
  @@index([modifiedBy])
}

model Conflict {
  id                  String    @id @default(cuid())
  type                String
  scheduleId1         String?
  scheduleId2         String?
  description         String
  severity            String    @default("warning")
  suggestedResolution String?
  resolutionOptions   String?   @default("[]")  // JSON array of resolution options
  autoResolvable      Boolean   @default(false)
  resolved            Boolean   @default(false)
  resolvedBy          String?
  resolvedAt          DateTime?
  resolutionAction    String?   // What action was taken to resolve
  rollbackData        String?   @default("{}")  // JSON of previous state for undo
  createdAt           DateTime  @default(now())
  facultyIds          String?
  subjectId           String?
  generationId        String?

  @@index([resolved])
  @@index([type])
  @@index([generationId])
  @@index([severity, resolved])
}

model AuditLog {
  id            String   @id @default(cuid())
  userId        String?
  action        String   // create, update, delete, resolve, undo, batch_update
  entity        String?  // schedule, conflict, user, etc.
  entityId      String?
  details       String?  @default("{}")  // JSON of action details
  previousState String?  @default("{}")  // JSON of state before action (for undo)
  newState      String?  @default("{}")  // JSON of state after action
  canUndo       Boolean  @default(false)
  undone        Boolean  @default(false)
  undoneBy      String?
  undoneAt      DateTime?
  undoOfLogId   String?  // Reference to original log if this is an undo action
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@index([action, undone])
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  category    String   @default("general")
  updatedAt   DateTime @updatedAt

  @@index([category])
}

// ============================================================================
// SCHEDULE VERSIONING & HISTORY
// ============================================================================

model ScheduleVersion {
  id              String   @id @default(cuid())
  versionName     String
  description     String?
  semester        String
  academicYear    String
  generatedAt     DateTime @default(now())
  generatedBy     String
  stats           String   @default("{}")  // JSON of GenerationStats
  scheduleCount   Int      @default(0)
  isActive        Boolean  @default(false)
  isArchived      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  snapshots       ScheduleSnapshot[]

  @@index([semester, academicYear])
  @@index([isActive])
  @@index([generatedAt])
}

model ScheduleSnapshot {
  id              String   @id @default(cuid())
  versionId       String
  subjectId       String
  subjectCode     String
  subjectName     String
  facultyId       String
  facultyName     String
  sectionId       String
  sectionName     String
  roomId          String
  roomName        String
  day             String
  startTime       String
  endTime         String
  status          String
  score           Float?
  scoreBreakdown  String?  // JSON of score breakdown
  createdAt       DateTime @default(now())
  
  version         ScheduleVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([versionId])
  @@index([facultyId])
  @@index([subjectId])
}

// ============================================================================
// GENERATION CONFIGURATION
// ============================================================================

model GenerationConfig {
  id              String   @id @default(cuid())
  name            String   @unique
  description     String?
  weights         String   @default("{}")  // JSON of ConstraintWeights
  options         String   @default("{}")  // JSON of GenerationOptions
  isPreset        Boolean  @default(false)
  isDefault       Boolean  @default(false)
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isPreset])
  @@index([isDefault])
}

// ============================================================================
// GENERATION SESSION (for progress tracking)
// ============================================================================

model GenerationSession {
  id              String   @id @default(cuid())
  status          String   @default("pending")  // pending, running, completed, failed, cancelled
  progress        Int      @default(0)
  totalTasks      Int      @default(0)
  assignedCount   Int      @default(0)
  unassignedCount Int      @default(0)
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  elapsedTimeMs   Int      @default(0)
  estimatedRemainingMs Int @default(0)
  error           String?
  stats           String?  // JSON of final stats
  createdBy       String
  versionId       String?  // Link to created version
  
  @@index([status])
  @@index([startedAt])
}

// ============================================================================
// ANALYTICS SNAPSHOT (for historical tracking)
// ============================================================================

model AnalyticsSnapshot {
  id                      String   @id @default(cuid())
  snapshotDate            DateTime @default(now())
  semester                String
  academicYear            String
  
  // Overall stats
  totalSchedules          Int      @default(0)
  totalFaculty            Int      @default(0)
  totalSubjects           Int      @default(0)
  totalSections           Int      @default(0)
  totalRooms              Int      @default(0)
  
  // Conflict stats
  totalConflicts          Int      @default(0)
  criticalConflicts       Int      @default(0)
  warningConflicts        Int      @default(0)
  resolvedConflicts       Int      @default(0)
  
  // Faculty workload stats
  avgFacultyUtilization   Float    @default(0)
  overloadedFaculty       Int      @default(0)
  underloadedFaculty      Int      @default(0)
  optimalLoadFaculty      Int      @default(0)
  
  // Time distribution
  morningClasses          Int      @default(0)  // 7AM-12PM
  afternoonClasses        Int      @default(0)  // 12PM-6PM
  eveningClasses          Int      @default(0)  // 6PM-9PM
  
  // Day distribution (JSON)
  dayDistribution         String   @default("{}")  // {Monday: 10, Tuesday: 8, ...}
  
  // Room utilization (JSON)
  roomUtilization         String   @default("{}")  // {room1: 85%, room2: 60%, ...}
  
  // Department breakdown (JSON)
  departmentStats         String   @default("{}")  // {dept1: {schedules: 10, conflicts: 2}, ...}
  
  // Peak hours analysis (JSON)
  peakHoursAnalysis       String   @default("{}")  // {07:00: 5, 08:00: 12, ...}
  
  // Generation quality score
  overallQualityScore     Float    @default(0)
  preferenceMatchRate     Float    @default(0)  // % of schedules matching preferences
  loadBalanceScore        Float    @default(0)
  
  createdAt               DateTime @default(now())
  
  @@index([snapshotDate])
  @@index([semester, academicYear])
  @@unique([semester, academicYear, snapshotDate])
}

// FEPC Scheduling System - PostgreSQL Schema for Production
// Use this schema when deploying to Render, Vercel, or other cloud platforms

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User roles: admin, department_head, faculty
model User {
  id             String             @id @default(cuid())
  uid            String             @unique
  name           String
  email          String             @unique
  password       String             // Hashed password
  role           String             @default("faculty") // admin | department_head | faculty
  departmentId   String?
  contractType   String             @default("full-time") // full-time | part-time
  maxUnits       Int                @default(24)
  specialization String             @default("[]") // JSON array stored as string
  image          String?            // Base64 encoded profile image
  phone          String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  
  department     Department?        @relation(fields: [departmentId], references: [id])
  schedules      Schedule[]
  preferences    FacultyPreference?
  notifications  Notification[]
  scheduleLogs   ScheduleLog[]
  auditLogs      AuditLog[]

  @@index([email])
  @@index([role])
  @@index([departmentId])
}

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String?  // Department code (e.g., CS, EE, ME)
  college   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  users     User[]
  subjects  Subject[]
  sections  Section[]
}

model Subject {
  id                     String   @id @default(cuid())
  subjectCode            String   @unique
  subjectName            String
  description            String?
  units                  Int
  departmentId           String
  requiredSpecialization String   @default("[]") // JSON array stored as string
  isActive               Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  
  department             Department @relation(fields: [departmentId], references: [id])
  schedules              Schedule[]
}

model Room {
  id         String   @id @default(cuid())
  roomName   String   @unique
  roomCode   String?  // Room code (e.g., R101, LAB-A)
  capacity   Int
  equipment  String   @default("[]") // JSON array stored as string
  building   String
  floor      Int?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  schedules  Schedule[]
}

model Section {
  id            String   @id @default(cuid())
  sectionName   String   @unique
  sectionCode   String?  // Section code (e.g., 1CS-A, 2EE-B)
  yearLevel     Int      // 1-5
  departmentId  String
  studentCount  Int
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  department    Department @relation(fields: [departmentId], references: [id])
  schedules     Schedule[]
}

model Schedule {
  id           String   @id @default(cuid())
  subjectId    String
  facultyId    String
  sectionId    String
  roomId       String
  day          String   // Monday, Tuesday, etc.
  startTime    String   // HH:MM format
  endTime      String   // HH:MM format
  status       String   @default("generated") // generated | approved | modified | conflict
  semester     String?  // e.g., "1st Semester 2024-2025"
  academicYear String?  // e.g., "2024-2025"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  subject      Subject  @relation(fields: [subjectId], references: [id])
  faculty      User     @relation(fields: [facultyId], references: [id])
  section      Section  @relation(fields: [sectionId], references: [id])
  room         Room     @relation(fields: [roomId], references: [id])
  logs         ScheduleLog[]

  @@index([facultyId, day, startTime])
  @@index([roomId, day, startTime])
  @@index([sectionId, day, startTime])
}

model FacultyPreference {
  id                   String   @id @default(cuid())
  facultyId            String   @unique
  preferredDays        String   @default("[]") // JSON array stored as string
  preferredTimeStart   String   @default("08:00") // HH:MM format
  preferredTimeEnd     String   @default("17:00") // HH:MM format
  preferredSubjects    String   @default("[]") // JSON array stored as string
  unavailableDays      String?  @default("[]") // JSON array of unavailable dates
  notes                String?  // Additional notes
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  
  faculty              User     @relation(fields: [facultyId], references: [id])
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  title      String
  message    String
  type       String   @default("info") // info | warning | success | error
  read       Boolean  @default(false)
  actionUrl  String?  // URL to navigate when clicked
  createdAt  DateTime @default(now())
  
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId, read])
}

model ScheduleLog {
  id          String   @id @default(cuid())
  scheduleId  String
  modifiedBy  String
  oldValue    String   @default("{}") // JSON stored as string
  newValue    String   @default("{}") // JSON stored as string
  action      String   // created | modified | deleted
  reason      String?  // Reason for modification
  timestamp   DateTime @default(now())
  
  schedule    Schedule @relation(fields: [scheduleId], references: [id])
  user        User     @relation(fields: [modifiedBy], references: [id])

  @@index([scheduleId])
  @@index([modifiedBy])
}

model Conflict {
  id                  String    @id @default(cuid())
  type                String    // faculty_double_booking | room_double_booking | section_overlap
  scheduleId1         String
  scheduleId2         String?
  description         String
  severity            String    @default("warning") // critical | warning | info
  suggestedResolution String?
  resolved            Boolean   @default(false)
  resolvedBy          String?
  resolvedAt          DateTime?
  createdAt           DateTime  @default(now())

  @@index([resolved])
}

model AuditLog {
  id        String    @id @default(cuid())
  userId    String?
  action    String    // login | logout | create | update | delete | generate
  entity    String?   // user | schedule | department, etc.
  entityId  String?
  details   String?   @default("{}") // JSON stored as string
  ipAddress String?
  userAgent String?
  createdAt DateTime  @default(now())
  
  user      User?     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  category    String   @default("general") // general | schedule | notification | security
  updatedAt   DateTime @updatedAt
  
  @@index([category])
}
